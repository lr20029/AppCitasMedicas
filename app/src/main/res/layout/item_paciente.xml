<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/MediCareCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <TextView android:id="@+id/tvInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="A" android:textSize="20sp"
                android:textStyle="bold" android:textColor="@color/primary"
                android:gravity="center" android:background="@drawable/bg_avatar_circle"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivRowFotoPaciente"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">

            <TextView android:id="@+id/tvNombrePaciente" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Nombre Apellido"
                android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>

            <TextView android:id="@+id/tvDui" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="00000000-0"
                android:textSize="12sp" android:textColor="?attr/colorPrimary"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tvTelefono" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0000-0000"
                    android:textSize="11sp" android:textColor="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  •  " android:textSize="11sp" android:textColor="?attr/colorOnSurface"/>
                <TextView android:id="@+id/tvTipoSangre" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="O+"
                    android:textSize="11sp" android:textColor="@color/status_cancelled"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical">
            <ImageButton android:id="@+id/btnEditPaciente" android:layout_width="32dp"
                android:layout_height="32dp" android:src="@drawable/ic_edit"
                android:background="@drawable/bg_rounded_accent" android:padding="4dp"
                android:contentDescription="Editar" android:layout_marginBottom="4dp"/>
            <ImageButton android:id="@+id/btnDeletePaciente" android:layout_width="32dp"
                android:layout_height="32dp" android:src="@drawable/ic_delete"
                android:background="@drawable/bg_status_cancelled" android:padding="4dp"
                android:contentDescription="Eliminar"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>