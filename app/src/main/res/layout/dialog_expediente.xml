<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Paciente" android:textSize="12sp" android:textColor="?attr/colorPrimary"
            android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/spPacienteExp" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="@drawable/bg_rounded_accent"
            android:padding="8dp" android:layout_marginBottom="12dp"/>

        <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Número de expediente" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etNumeroExp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2">
            <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Peso (kg)"
                android:layout_marginEnd="8dp" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPeso"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Talla (m)" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etTalla"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Antecedentes familiares" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAntFamiliares"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Antecedentes personales" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAntPersonales"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Medicamentos actuales" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMedicamentos"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Enfermedades crónicas" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEnfCronicas"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/MediCareInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Cirugías previas">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etCirugias"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>